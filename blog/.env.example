# ============================================================================
# ArenaGo - Secure Environment Variables Template
# ============================================================================
# 
# NEVER commit this file to Git!
# Copy to .env and fill in actual values
#
# For production:
#   cp .env.example .env
#   nano .env  # Edit with real values
#   # Add to .gitignore if not already there: .env

# ============================================================================
# DJANGO SETTINGS
# ============================================================================

# Settings module (secure-dev for development, production for production)
DJANGO_SETTINGS_MODULE=blog.settings_secure_dev

# Debug mode (NEVER True in production)
DEBUG=False

# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(50))'
# REQUIRED for production
SECRET_KEY=your-generated-secret-key-here

# ============================================================================
# ALLOWED HOSTS & CORS
# ============================================================================

# Comma-separated list of allowed domains
# Development: localhost,127.0.0.1
# Production: arenago.uz,www.arenago.uz
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS allowed origins (where frontend is hosted)
# Example: https://arenago.uz, https://app.arenago.uz
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CSRF trusted origins (form submissions from these domains)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (development only)
# SQLite connections don't need URL, handled in settings

# PostgreSQL (production)
# Format: postgres://username:password@hostname:port/database
# Example: postgres://arenago:secure_password@db.example.com:5432/arenago_prod
# 
# To create PostgreSQL user:
#   CREATE USER arenago WITH PASSWORD 'secure_password';
#   CREATE DATABASE arenago_prod OWNER arenago;
#   GRANT ALL PRIVILEGES ON DATABASE arenago_prod TO arenago;

DATABASE_URL=postgres://user:password@localhost:5432/arenago

# Connection options
DB_NAME=arenago
DB_USER=arenago
DB_PASSWORD=your-database-password
DB_HOST=db.example.com
DB_PORT=5432

# ============================================================================
# REDIS CONFIGURATION (Caching & Channels)
# ============================================================================

# Format: redis://[:password]@host:port/database
# Example local: redis://localhost:6379/0
# Example with auth: redis://:password@redis.example.com:6379/0

REDIS_URL=redis://localhost:6379/0
REDIS_AUTH_PASSWORD=your-redis-password-if-protected

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Enable HTTPS redirect (set to True in production)
SECURE_SSL_REDIRECT=False

# Secure cookies (set to True in production with HTTPS)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Gmail Example:
# 1. Create Google App Password: https://myaccount.google.com/apppasswords
# 2. Use the 16-character password below

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Or use SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.your-sendgrid-key

DEFAULT_FROM_EMAIL=noreply@arenago.uz
SUPPORT_EMAIL=support@arenago.uz

# ============================================================================
# ADMIN USER CREDENTIALS
# ============================================================================

# If not set, a secure password will be generated
# Set BEFORE running: python manage.py migrate

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@arenago.uz
ADMIN_PASSWORD=your-secure-admin-password

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Click Payment Gateway (Uzbekistan)
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SERVICE_ID=your-click-service-id
CLICK_API_KEY=your-click-api-key
CLICK_API_SECRET=your-click-api-secret

# Eskiz SMS Gateway (Uzbekistan OTP)
ESKIZ_EMAIL=your-eskiz-email@example.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_FROM_ID=4546

# Firebase (Push Notifications - optional)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Sentry (Error Tracking)
SENTRY_DSN=https://key@sentry.io/project

# Loggly (Log Aggregation)
LOGGLY_TOKEN=your-loggly-token

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable admin panel (set to False to disable)
ENABLE_ADMIN=True

# Enable payment processing
ENABLE_PAYMENTS=True

# ============================================================================
# DEPLOYMENT PLATFORM SPECIFIC
# ============================================================================

# Render.com
RENDER_SERVICE_ID=srv_xxxxx

# Railway.app
RAILWAY_SERVICE_ID=svc_xxxxx

# AWS RDS
AWS_RDS_ENDPOINT=arenago.xxxxx.rds.amazonaws.com

# AWS S3 (Static/Media file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=arenago-bucket
AWS_S3_REGION_NAME=us-east-1

# ============================================================================
# SECURITY HEADERS & CSP
# ============================================================================

# Configure Content Security Policy
# See settings.py for detailed CSP configuration
SECURE_CSP_ENABLED=True

# ============================================================================
# DEVELOPER SETTINGS
# ============================================================================

# Testing
TESTING=False

# API Documentation
API_DOCS_ENABLED=True

# ============================================================================
# CHECKLIST FOR DEPLOYMENT
# ============================================================================

# Before deploying, ensure:
# [ ] SECRET_KEY is set and cryptographically secure
# [ ] DEBUG = False
# [ ] ALLOWED_HOSTS contains only your domains
# [ ] DATABASE_URL uses PostgreSQL in production
# [ ] REDIS_URL is configured and accessible
# [ ] EMAIL credentials are correct
# [ ] CORS_ALLOWED_ORIGINS matches frontend domain
# [ ] All third-party API keys are set
# [ ] HTTPS is enabled (SECURE_SSL_REDIRECT=True)
# [ ] Secure cookies are enabled
# [ ] Admin password is secure and stored safely
# [ ] .env file is in .gitignore
# [ ] Regular backups are configured
# [ ] Monitoring/logging is enabled
# [ ] SSL certificate is valid and renewable
